generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("agent") // "admin" | "agent"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions        Session[]
  assignedTickets Ticket[]  @relation("AssignedAgent")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id              String   @id @default(cuid())
  subject         String
  customerEmail   String
  status          String   @default("open") // "open" | "resolved" | "closed"
  category        String? // "general_question" | "technical_question" | "refund_request"
  priority        String? // "urgent" | "high" | "normal" | "low"
  assignedAgentId String?
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedAgent User?     @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  messages      Message[]
}

model Message {
  id             String   @id @default(cuid())
  ticketId       String
  body           String
  isFromCustomer Boolean  @default(true)
  createdAt      DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model KnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
